PORT=4000
DEV_PORT_FALLBACK=0
# Single origin or comma-separated list (prod + staging). Required on Vercel.
FRONTEND_ORIGIN=http://localhost:3000
# Set to 1 to allow any https://*.vercel.app Origin (preview URLs). Use with care.
CORS_ALLOW_VERCEL_PREVIEW_ORIGINS=0
# Encode special chars in password: # %23  $ %24  @ %40  (or paste URI from Supabase)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# Optional; on Vercel defaults to a small pool. Use a DB pooler URL in production.
DATABASE_POOL_MAX=
# Set to 0 for Supabase/local Node if you see SELF_SIGNED_CERT_IN_CHAIN (dev only; use verify-full in prod if possible)
DATABASE_SSL_REJECT_UNAUTHORIZED=1
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local: backend origin. Vercel: https://<your-deployment>.vercel.app/auth/google/callback (or custom domain)
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
TOKEN_ENCRYPTION_KEY=
ANTHROPIC_API_KEY=
CRON_SECRET=
